# Environment Variables for CacaoTrack
# Copy this file to .env and fill in your production values

# API Configuration (Required for production)
EXPO_PUBLIC_API_BASE_URL=https://your-production-api.com

# Firebase Configuration (Optional - overrides firebaseConfig.js defaults)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Development Only
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.40:8000
